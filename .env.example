# PostgreSQL
DATABASE_URL=postgresql://rwr_agent:rwr_agent_secret@localhost:5432/rwr_agent
# DATABASE_TABLE=rwr_documents

# Database provider: "pg" (default, for Docker/local) or "neon" (for Neon serverless)
DATABASE_PROVIDER=pg

# Neon / Serverless Postgres: reduce pool max and enable SSL
# DATABASE_POOL_MAX=10
# DATABASE_SSL=true

# SiliconFlow (Embeddings)
SILICONFLOW_API_KEY=sk-xxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Reranker (SiliconFlow)
# RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Ingestion tuning
# INGEST_BATCH_SIZE=8
# INGEST_CONCURRENCY=2

# LLM (Chat Completions)
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=600

# LangFuse Observability
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_TRACING_ENVIRONMENT=production  # default: "default"

# Multi-turn Memory
# SUMMARY_INTERVAL_TURNS=3
# SUMMARY_MODEL=Qwen/Qwen2.5-7B-Instruct

# Server
PORT=3000

# ──────────────────────────────────────────
# Vercel + Neon production example:
# ──────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/db?sslmode=require
# DATABASE_PROVIDER=neon
# DATABASE_POOL_MAX=10
# DATABASE_SSL=true
# SILICONFLOW_API_KEY=sk-xxx
# LLM_API_KEY=sk-xxx