{
  "name": "rwr-data-agent",
  "version": "1.0.0",
  "description": "Running With Rifles AI Agent - RAG API for game data",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run web:build",
    "dev": "node --import tsx --watch src/api/server.ts",
    "start": "node dist/api/server.js",
    "db:migrate": "node --import tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "extract": "node --import tsx src/ingestion/extract.ts",
    "extract:prod": "node dist/ingestion/extract.js",
    "embed": "node --import tsx src/ingestion/embed.ts",
    "embed:prod": "node dist/ingestion/embed.js",
    "ingest": "node --import tsx src/ingestion/cli.ts",
    "ingest:prod": "node dist/ingestion/cli.js",
    "web:install": "npm --prefix web install",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "rwr",
    "rag",
    "ai",
    "fastify"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.3.0",
    "@neondatabase/serverless": "^0.10.4",
    "ai": "^6.0.177",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.7.2",
    "fastify": "^5.8.5",
    "openai": "^6.35.0",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
